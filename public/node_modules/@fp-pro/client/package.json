{
  "name": "@fp-pro/client",
  "description": "FingerprintJS Pro client agent",
  "version": "2.8.3",
  "author": "FingerprintJS<support@fingerprintjs.com>",
  "keywords": [
    "browser",
    "fingerprint",
    "identification",
    "fraud detection"
  ],
  "main": "dist/cjs/fp.min.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist/cjs/fp.min.js",
    "dist/umd/fp.min.js",
    "dist/src/index.d.ts",
    "dist/src/fp.d.ts",
    "dist/src/config.d.ts",
    "dist/src/response.d.ts",
    "dist/src/constants.d.ts"
  ],
  "scripts": {
    "prettier-format": "prettier --config .prettierrc 'src/**/*.ts' --write",
    "lint": "eslint src/**/*.ts",
    "clean": "rimraf ./dist",
    "build:ts": "tsc",
    "build:lib": "rollup -c",
    "build:lib:release": "BUILD=production rollup -c",
    "build": "yarn run clean && yarn run build:ts && yarn run build:lib",
    "build:release": "yarn run clean && yarn run build:ts && yarn run build:lib:release",
    "cloudfront:release": "AWS_REGION=us-east-1 node scripts/cloudfront/release.js",
    "npm:release": "yarn publish --access public",
    "test:chrome": "karma start --single-run --browsers ChromeHeadlessNoSandbox tests/karma.conf.js",
    "test:chrome:cjs": "MODULE_TYPE=cjs yarn run test:chrome",
    "test:chrome:incognito": "karma start --single-run --browsers ChromeIncognito tests/karma.conf.js",
    "test:firefox": "karma start --single-run --browsers FirefoxHeadless tests/karma.conf.js",
    "test:firefox:incognito": "karma start --single-run --browsers FirefoxIncognito tests/karma.conf.js",
    "test:safari": "karma start --single-run --browsers Safari tests/karma.conf.js",
    "test:chrome:debug": "karma start --single-run false --browsers=Chrome tests/karma.conf.js",
    "test:firefox:debug": "karma start --single-run false --browsers FirefoxDebug tests/karma.conf.js",
    "test:all": "yarn run test:chrome && yarn run test:chrome:cjs && yarn run test:chrome:incognito && yarn run test:firefox && yarn run test:firefox:incognito && yarn run test:safari"
  },
  "devDependencies": {
    "@rollup/plugin-json": "^4.1.0",
    "@typescript-eslint/eslint-plugin": "^3.7.1",
    "@typescript-eslint/parser": "^3.7.1",
    "aws-sdk": "^2.724.0",
    "eslint": "^7.5.0",
    "eslint-config-prettier": "^6.11.0",
    "eslint-plugin-prettier": "^3.1.4",
    "jasmine-expect": "^4",
    "karma": "^5.1.1",
    "karma-chrome-launcher": "^3.1.0",
    "karma-firefox-launcher": "^1.3.0",
    "karma-jasmine": "^3.3.1",
    "karma-jasmine-matchers": "^4.0.2",
    "karma-safari-launcher": "^1.0.0",
    "prettier": "^2.0.5",
    "promise-polyfill": "^8.1.3",
    "rimraf": "^3.0.2",
    "rollup": "^2.23.0",
    "rollup-plugin-banner": "^0.2.1",
    "rollup-plugin-node-resolve": "^5.2.0",
    "rollup-plugin-terser": "^6.1.0",
    "typescript": "^4.0.2"
  }
}
